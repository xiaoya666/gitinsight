<idea-plugin>
    <id>com.power.gitinsight</id>
    <name>GitInsight</name>
    <vendor email="xiaoya666@users.noreply.github.com" url="https://github.com/xiaoya666/gitinsight">fangyajun</vendor>

    <description><![CDATA[
        <h2>GitInsight — Git change-risk dashboard for IntelliJ IDEs</h2>
        <p>Not just <code>git blame</code>, but <code>git insight</code>. GitInsight surfaces what plain Git can't: how risky your change really is, who else has been burned by this file, and which lines have a history of incidents.</p>
        <ul>
            <li><b>Enhanced Blame</b> — hover any line to see author, recent modify frequency, and an incident badge when the commit was a revert / hotfix / rollback.</li>
            <li><b>Hotspot Heatmap</b> — multi-factor score (modify count, recency, rollbacks, author diversity) shown as a gutter color band and a sortable dashboard tool window.</li>
            <li><b>Commit Risk Score</b> — pre-commit analysis with an 8-rule engine (payment / SQL / concurrency / large delete / cross-module / no-tests / CI / hotspot-touch). Per-project YAML overrides via <code>.gitinsight/risk.yml</code>.</li>
            <li><b>Incident Commit Tracking</b> — automatically classifies revert / hotfix / rollback commits during the history scan; surfaces them in the blame tooltip.</li>
            <li><b>Activity Dashboard</b> — your last-30-days commit count, incident rate, and recent commit list, in a dedicated tool-window tab.</li>
            <li><b>AI Commit Message</b> &amp; <b>AI Diff Review</b> — optional AI assistance. Supports OpenAI, Anthropic Claude, DeepSeek, Ollama, and a free Cloudflare Workers AI fallback. API keys stored in IDE PasswordSafe.</li>
            <li><b>Anonymous Telemetry</b> — disabled by default. When enabled, only sends exception stacks, IDE / plugin version, and a random install id. Never code, file paths, usernames, or git URLs.</li>
        </ul>
        <p>Free core (Apache-2.0 open source). Compatible with IDEA 2024.2 – 2025.3, JVM 21.</p>
    ]]></description>

    <change-notes><![CDATA[
        <h3>1.0.1</h3>
        <ul>
            <li>Initial release of GitInsight: Enhanced Blame with incident badge, Hotspot Heatmap + dashboard, Commit Risk Score with 8-rule engine, per-project YAML rule overrides, AI commit message + diff review, personal activity dashboard, and opt-in anonymous telemetry.</li>
            <li>Compatibility: IDEA 2024.2 – 2025.3, JVM 21.</li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity
                implementation="com.power.gitinsight.GitInsightStartupActivity"/>

        <toolWindow
                id="GitInsight"
                anchor="right"
                factoryClass="com.power.gitinsight.toolwindow.GitInsightToolWindowFactory"/>

        <notificationGroup
                id="GitInsight Notifications"
                displayType="BALLOON"/>

        <applicationService
                serviceInterface="com.power.gitinsight.infra.git.GitAdapter"
                serviceImplementation="com.power.gitinsight.infra.git.Git4IdeaAdapter"/>

        <projectService
                serviceImplementation="com.power.gitinsight.infra.git.GitChangeListener"/>

        <projectService
                serviceImplementation="com.power.gitinsight.infra.storage.BlameStorage"/>

        <projectService
                serviceImplementation="com.power.gitinsight.domain.blame.BlameService"/>

        <projectService
                serviceImplementation="com.power.gitinsight.domain.hotspot.HotspotService"/>

        <projectService
                serviceImplementation="com.power.gitinsight.domain.incident.IncidentService"/>

        <projectService
                serviceImplementation="com.power.gitinsight.domain.activity.ActivityService"/>

        <checkinHandlerFactory
                implementation="com.power.gitinsight.infra.checkin.RiskCheckinHandlerFactory"/>

        <applicationService
                serviceImplementation="com.power.gitinsight.domain.risk.RiskSettings"/>

        <projectService
                serviceImplementation="com.power.gitinsight.domain.risk.RiskRulesProjectLoader"/>

        <applicationConfigurable
                parentId="tools"
                id="com.power.gitinsight.commitRisk"
                displayName="GitInsight: Risk Rules"
                instance="com.power.gitinsight.ui.checkin.RiskSettingsConfigurable"/>

        <applicationService
                serviceImplementation="com.power.gitinsight.domain.ai.AiSettings"/>

        <applicationConfigurable
                parentId="tools"
                id="com.power.gitinsight.ai"
                displayName="GitInsight: AI"
                instance="com.power.gitinsight.ui.ai.AiSettingsConfigurable"/>

        <applicationService
                serviceImplementation="com.power.gitinsight.domain.license.LicenseSettings"/>

        <applicationConfigurable
                parentId="tools"
                id="com.power.gitinsight.license"
                displayName="GitInsight: License"
                instance="com.power.gitinsight.ui.license.LicenseSettingsConfigurable"/>

        <applicationService
                serviceImplementation="com.power.gitinsight.domain.telemetry.TelemetrySettings"/>

        <applicationService
                serviceImplementation="com.power.gitinsight.domain.telemetry.TelemetryService"/>

        <applicationConfigurable
                parentId="tools"
                id="com.power.gitinsight.telemetry"
                displayName="GitInsight: Telemetry"
                instance="com.power.gitinsight.ui.telemetry.TelemetrySettingsConfigurable"/>

        <codeInsight.lineMarkerProvider
                language="JAVA"
                implementationClass="com.power.gitinsight.ui.tooltip.BlameLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider
                language="kotlin"
                implementationClass="com.power.gitinsight.ui.tooltip.BlameLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider
                language="TEXT"
                implementationClass="com.power.gitinsight.ui.tooltip.BlameLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider
                language="XML"
                implementationClass="com.power.gitinsight.ui.tooltip.BlameLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider
                language="JavaScript"
                implementationClass="com.power.gitinsight.ui.tooltip.BlameLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider
                language="TypeScript"
                implementationClass="com.power.gitinsight.ui.tooltip.BlameLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider
                language="Python"
                implementationClass="com.power.gitinsight.ui.tooltip.BlameLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider
                language="Groovy"
                implementationClass="com.power.gitinsight.ui.tooltip.BlameLineMarkerProvider"/>
    </extensions>

    <projectListeners>
        <listener
                class="com.power.gitinsight.ui.gutter.HotspotGutterInstaller"
                topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"/>
    </projectListeners>

    <actions>
        <action
                id="GitInsight.HelloAction"
                class="com.power.gitinsight.action.HelloAction"
                text="GitInsight: Hello"
                description="Sanity check that the GitInsight plugin is loaded.">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action
                id="GitInsight.GenerateCommitMessage"
                class="com.power.gitinsight.ui.ai.GenerateCommitMessageAction"
                text="✨ GitInsight: AI Commit Message"
                description="Generate a commit message from the staged changes using the configured AI provider.">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="last"/>
        </action>

        <action
                id="GitInsight.AiReviewDiff"
                class="com.power.gitinsight.ui.ai.AiReviewAction"
                text="🔎 GitInsight: AI Review Diff [Pro Preview]"
                description="Pro Preview — free during 1.0.x. Asks the configured AI provider to review current changes for bugs and code smells.">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="ChangesViewPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
