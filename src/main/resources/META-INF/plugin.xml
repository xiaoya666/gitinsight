<idea-plugin>
    <id>com.power.gitinsight</id>
    <name>GitInsight</name>
    <vendor email="support@gitinsight.dev" url="https://github.com/xiaoya666/gitinsight">Power</vendor>

    <description><![CDATA[
        <h2>GitInsight — Git change-risk dashboard for IntelliJ IDEs</h2>
        <p>Not just <code>git blame</code>, but <code>git insight</code>:</p>
        <ul>
            <li><b>Enhanced Blame</b> — hover a line to see author, modify frequency, and incident links.</li>
            <li><b>Hotspot Heatmap</b> — gutter colors mark high-risk files (frequent modify / rollback / conflicts).</li>
            <li><b>Commit Risk Score</b> — get a risk evaluation before you commit, with rule-driven explanations.</li>
            <li><b>AI Commit / AI Review</b> — optional AI assistance (BYO key or built-in fallback).</li>
        </ul>
        <p>Free core (Apache-2.0 open source). Pro features available.</p>
    ]]></description>

    <change-notes><![CDATA[
        <h3>1.0.0</h3>
        <ul>
            <li>First stable release — feature set frozen from 0.2.0 with broader IDE compatibility.</li>
            <li>Compatibility: IDEA 2024.2 – 2025.3.</li>
        </ul>
        <h3>0.2.0</h3>
        <ul>
            <li><b>Enhanced Blame</b> — gutter icon with rich tooltip per line; cached in SQLite.</li>
            <li><b>Hotspot Heatmap</b> — multi-factor score (modify / rollback / recency / authors); 3px gutter color band + dashboard ToolWindow with sortable top-50 list and double-click to open.</li>
            <li><b>Commit Risk Score</b> — checkin handler runs an 8-rule engine (payment / SQL / concurrency / large delete / cross-module / no-tests / CI / hotspot-touch) and surfaces a dialog for MEDIUM / HIGH commits. Per-rule on/off in Preferences > Tools > GitInsight: Commit Risk.</li>
            <li><b>AI Commit Message</b> — Tools menu / commit area button; supports OpenAI, Anthropic Claude, DeepSeek, Ollama, and a free Cloudflare Workers AI fallback. API keys stored in IDE PasswordSafe.</li>
            <li><b>AI Diff Review</b> — right-click changelist or use the "让 AI 审一下" button inside the Risk dialog; surfaces NPE / BigDecimal / @Transactional / lock / SQL / resource-leak findings as Markdown.</li>
            <li>Compatibility: IDEA 2024.2-2024.3, JVM 21.</li>
        </ul>
        <h3>0.1.0</h3>
        <ul>
            <li>Initial scaffold.</li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity
                implementation="com.power.gitinsight.GitInsightStartupActivity"/>

        <toolWindow
                id="GitInsight"
                anchor="right"
                factoryClass="com.power.gitinsight.toolwindow.GitInsightToolWindowFactory"/>

        <notificationGroup
                id="GitInsight Notifications"
                displayType="BALLOON"/>

        <applicationService
                serviceInterface="com.power.gitinsight.infra.git.GitAdapter"
                serviceImplementation="com.power.gitinsight.infra.git.Git4IdeaAdapter"/>

        <projectService
                serviceImplementation="com.power.gitinsight.infra.git.GitChangeListener"/>

        <projectService
                serviceImplementation="com.power.gitinsight.infra.storage.BlameStorage"/>

        <projectService
                serviceImplementation="com.power.gitinsight.domain.blame.BlameService"/>

        <projectService
                serviceImplementation="com.power.gitinsight.domain.hotspot.HotspotService"/>

        <checkinHandlerFactory
                implementation="com.power.gitinsight.infra.checkin.RiskCheckinHandlerFactory"/>

        <applicationService
                serviceImplementation="com.power.gitinsight.domain.risk.RiskSettings"/>

        <applicationConfigurable
                parentId="tools"
                id="com.power.gitinsight.commitRisk"
                displayName="GitInsight: Commit Risk"
                instance="com.power.gitinsight.ui.checkin.RiskSettingsConfigurable"/>

        <applicationService
                serviceImplementation="com.power.gitinsight.domain.ai.AiSettings"/>

        <applicationConfigurable
                parentId="tools"
                id="com.power.gitinsight.ai"
                displayName="GitInsight: AI"
                instance="com.power.gitinsight.ui.ai.AiSettingsConfigurable"/>

        <codeInsight.lineMarkerProvider
                language="JAVA"
                implementationClass="com.power.gitinsight.ui.tooltip.BlameLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider
                language="kotlin"
                implementationClass="com.power.gitinsight.ui.tooltip.BlameLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider
                language="TEXT"
                implementationClass="com.power.gitinsight.ui.tooltip.BlameLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider
                language="XML"
                implementationClass="com.power.gitinsight.ui.tooltip.BlameLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider
                language="JavaScript"
                implementationClass="com.power.gitinsight.ui.tooltip.BlameLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider
                language="TypeScript"
                implementationClass="com.power.gitinsight.ui.tooltip.BlameLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider
                language="Python"
                implementationClass="com.power.gitinsight.ui.tooltip.BlameLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider
                language="Groovy"
                implementationClass="com.power.gitinsight.ui.tooltip.BlameLineMarkerProvider"/>
    </extensions>

    <projectListeners>
        <listener
                class="com.power.gitinsight.ui.gutter.HotspotGutterInstaller"
                topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"/>
    </projectListeners>

    <actions>
        <action
                id="GitInsight.HelloAction"
                class="com.power.gitinsight.action.HelloAction"
                text="GitInsight: Hello"
                description="Sanity check that the GitInsight plugin is loaded.">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action
                id="GitInsight.GenerateCommitMessage"
                class="com.power.gitinsight.ui.ai.GenerateCommitMessageAction"
                text="✨ GitInsight: AI Commit Message"
                description="Generate a commit message from the staged changes using the configured AI provider.">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="last"/>
        </action>

        <action
                id="GitInsight.AiReviewDiff"
                class="com.power.gitinsight.ui.ai.AiReviewAction"
                text="🔎 GitInsight: AI Review Diff"
                description="Ask the configured AI provider to review the current changes for bugs and code smells.">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="ChangesViewPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
